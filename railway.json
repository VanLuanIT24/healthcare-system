{
  "name": "Healthcare System",
  "description": "Full-stack healthcare management system with appointment booking, patient portal, and multi-role dashboards",
  "keywords": [
    "healthcare",
    "medical",
    "appointment",
    "patient-portal",
    "nodejs",
    "react",
    "mongodb"
  ],
  "services": [
    {
      "id": "mongodb",
      "name": "MongoDB",
      "type": "database"
    },
    {
      "id": "backend",
      "name": "Backend API",
      "type": "service",
      "rootDirectory": "healthcare-backend",
      "buildCommand": "npm install",
      "startCommand": "npm start",
      "port": 5000,
      "variables": {
        "NODE_ENV": "production",
        "PORT": "5000"
      }
    },
    {
      "id": "frontend",
      "name": "Frontend",
      "type": "service",
      "rootDirectory": "healthcare-frontend",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npm run preview",
      "port": 3000,
      "variables": {
        "VITE_API_URL": "${{ BACKEND_URL }}/api"
      }
    }
  ]
}
