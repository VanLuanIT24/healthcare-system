# Healthcare System - Docker Environment Configuration
# ============================================
# Thay đổi các giá trị sau và lưu vào file .env
# ============================================

# 🌍 SERVER & ENVIRONMENT
PORT=5000
NODE_ENV=development

# 🗄️ MONGODB CREDENTIALS
MONGO_USER=mongo
MONGO_PASSWORD=change_this_to_secure_password

# 🔐 JWT SECRETS (THAY ĐỔI NHỮNG GIÁ TRỊ NÀY CHO PRODUCTION!)
JWT_ACCESS_SECRET=healthcare_system_access_secret_key_change_this_for_production
JWT_REFRESH_SECRET=healthcare_system_refresh_secret_key_change_this_for_production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# 🧂 PASSWORD SECURITY
SALT_ROUNDS=12

# 📧 EMAIL SERVICE (Optional)
EMAIL_FROM=noreply@healthcare-system.vn
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# 👑 SUPER ADMIN
SUPER_ADMIN_EMAIL=superadmin@healthcare.com
SUPER_ADMIN_PASSWORD=SuperSecurePassword2024!
SUPER_ADMIN_NAME=System Administrator

# 🏥 HOSPITAL INFO
HOSPITAL_NAME=Healthcare System Hospital
SUPPORT_EMAIL=support@healthcare.vn
SUPPORT_PHONE=+84-28-3829-8149

# 📊 LOGGING & AUDIT
LOG_LEVEL=debug
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=90

# 📈 PERFORMANCE
DB_MAX_POOL_SIZE=20
DB_MIN_POOL_SIZE=5
REQUEST_TIMEOUT=30000
JSON_BODY_LIMIT=10mb
