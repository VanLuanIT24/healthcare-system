# ======================================
# 🚀 PRODUCTION ENVIRONMENT CONFIGURATION
# (Copy to .env.production for deployment)
# ======================================

# MongoDB Configuration (Update with your MongoDB Atlas URI)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/healthcare?retryWrites=true&w=majority

# Node Environment
NODE_ENV=production

# Backend Port
PORT=5000

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_change_this_in_production_12345
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_change_this_in_production_67890

# JWT Expiration
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Password Hashing
SALT_ROUNDS=12

# Logging
LOG_LEVEL=info

# ======================================
# 🔐 SUPER ADMIN CREDENTIALS
# IMPORTANT: Change these after first login!
# ======================================
SUPER_ADMIN_EMAIL=admin@healthcare.com
SUPER_ADMIN_PASSWORD=@Admin123
SUPER_ADMIN_NAME=System Administrator

# ======================================
# 📧 EMAIL CONFIGURATION
# ======================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@healthcare.com

# ======================================
# 🔒 SECURITY SETTINGS
# ======================================
# CORS Origins (comma-separated)
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Audit Log Retention (days)
AUDIT_LOG_RETENTION_DAYS=90

# ======================================
# 🎨 FRONTEND CONFIGURATION
# ======================================
# API URL (used by frontend to communicate with backend)
VITE_API_URL=https://api.yourdomain.com

# ======================================
# 📱 APPLICATION SETTINGS
# ======================================
# Features
ENABLE_PATIENT_PORTAL=true
ENABLE_SUPER_ADMIN_DASHBOARD=true

# Audit Logging
ENABLE_AUDIT_LOGGING=true
AUDIT_SENSITIVE_OPERATIONS=true

# Health Check Interval (ms)
HEALTH_CHECK_INTERVAL=30000
